#!/bin/bash

source "${MDS_SCRIPTS}/utils/ascii_menu.sh"

GIT_BASE_DIR="$(git rev-parse --show-toplevel 2> /dev/null)"
[[ -z "${GIT_BASE_DIR}" ]] && cout fail "Not a git repository"

declare -i rev_chuck_size=50
declare path="."

while (( $# > 0 ))
do
    if [[ "${1}" =~ ^[0-9]+$ ]]
    then
        rev_chuck_size="${1}"
    else
        path="${1}"
    fi
    shift
done

mapfile -t commit_logs < <(
    printf "%s"\
        "$(git log -${rev_chuck_size} --abbrev-commit --follow -- "${path}" 2> /dev/null \
            | grep -A 4 '^commit [a-z0-9]\+$' \
            | sed -E '/^( |-)*$/d;s/^ *//g')" \
    )

declare -i log_size=${#commit_logs[@]}
if (( log_size == 0 ))
then
    cout fail "Couldn't retrieve revision log"
fi

declare -a commits_menu=()
declare -g -a commit_hashes=()
for (( i=0; i<log_size; i+=4 ))
do
    # split commit data
    # shellcheck disable=SC2068
    set -- ${commit_logs[@]:i:3}
    commits_menu+=( "${1^} <${CYAN}${2}${WHITE}> ${YELLOW}'${commit_logs[$((i+3))]}'${WHITE} by ${GREEN}${4}${WHITE} at ${PURPLE}${7} ${8} ${9} ${11}" )
    commit_hashes+=( "${2}" )
done

function modified_files_callback() {
    case "${key}" in
        [vV]|"")
            if ! git -C "${GIT_BASE_DIR}" difftool --tool=nvimdiff -y "${hash_selected}~" "${hash_selected}" "${menu_item_key_selected}";
            then
                # revision or path is no longer in the working tree
                git -C "${GIT_BASE_DIR}" difftool --tool=nvimdiff -y "${hash_selected}~" "${hash_selected}"
            fi
            ;;
        [hH])
            gldiff "${menu_item_key_selected}"
            ;;
        [oO])
            nvim -R "${GIT_BASE_DIR}/${menu_item_key_selected}"
            ;;
    esac
}

function modified_files_menu() {
    local -a files_menu=()
    mapfile -t files_menu < <( git diff-tree --no-commit-id --name-only -r "${hash_selected}" )
    ascii_menu_create files_menu files_menu "Git log <${menu_item_selected}>" "(V)iew (H)istory (O)pen (Q)uit" modified_files_callback
}

function gldiff_callback() {
    local hash_selected="${menu_item_key_selected}"
    case ${key} in
        [vV]|"")
            modified_files_menu
            ;;
    esac
}

menu_title="Git log"
[[ "${path}" != "." ]] && menu_title+=" for ${BROWN}«${path}»${BLK}"

ascii_menu_create commits_menu commit_hashes "${menu_title}" "(V)iew (Q)uit" gldiff_callback
