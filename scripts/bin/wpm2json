#!/usr/bin/env bash

source "${MDS_SCRIPTS}/utils/cout.sh"

(( $# < 1 )) && cfail "Usage: wpm2json input [-o,--output|-j,--json]"

input_file="${1}"
opt_output="${2:--j}"
[[ -f "${input_file}" ]] || cfail "Unable to open «${input_file}»"

function print_json_format() {
    echo "["
    printf '{"author": "madophs",\n"title":"custom",\n"text": "%s",\n"id": %s}%s\n' \
           "${quotes[@]}"
    echo "]"
}

declare -a quotes=()
mapfile -t quotes < <(
    awk '!a[$0]++' "${input_file}" |
    sed -e '/^[[:space:]]*$/d' -e 's/"/\\"/g' -e "s/’/'/g" -e 's/—/-/g' |
    awk '{print $0"\n"++i"\n,"}' |
    head -n -1
)

case ${opt_output} in
    -o|--output)
        print_json_format
        ;;
    -j|--json)
        print_json_format | jq
        ;;
esac
