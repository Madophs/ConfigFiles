#!/bin/bash

source "${MDS_SCRIPTS}/utils/ascii_menu.sh"

git status -u &> /dev/null || cout fail "Not a git repository"
GIT_BASE_DIR="$(git rev-parse --show-toplevel 2> /dev/null)"

function get_nonstaged_files() {
    local -n untracked_files_menu_ref=${1}
    local -n untracked_files_keys_ref=${2}

    mapfile -t untracked_files_menu_ref < <(git status -u -s 2> /dev/null | sort -k 2)
    (( ${#untracked_files_menu_ref[@]} == 0 ))\
        && cout info "No untracked files available"\
        && exit 0

    local status filename item
    for (( i=0; i<${#untracked_files_menu_ref[@]}; i+=1 ))
    do
        item="${untracked_files_menu_ref[${i}]}"
        status="${item:0:3}"
        filename="${item##${status}}"
        [[ "${status}" == "M  " ]] && untracked_files_menu_ref[i]="${filename} (${GREEN}Staged${WHITE})"
        [[ "${status}" == " M " ]] && untracked_files_menu_ref[i]="${filename} (${YELLOW}Modified${WHITE})"
        [[ "${status}" == "MM " ]] && untracked_files_menu_ref[i]="${filename} (${GREEN}Staged Hunks${WHITE})"
        [[ "${status}" == "AM " ]] && untracked_files_menu_ref[i]="${filename} (${YELLOW}Added With Unstaged Mofications${WHITE})"
        [[ "${status}" == "A  " ]] && untracked_files_menu_ref[i]="${filename} (${GREEN}Added${WHITE})"
        [[ "${status}" == "?? " ]] && untracked_files_menu_ref[i]="${filename} (${CYAN}New${WHITE})"
        [[ "${status}" == "D  " ]] && untracked_files_menu_ref[i]="${filename} (${PURPLE}Deleted${WHITE})"
        [[ "${status}" == " D " ]] && untracked_files_menu_ref[i]="${filename} (${RED}Delete${WHITE})"
        [[ "${status}" == "R  " ]] && untracked_files_menu_ref[i]="${filename} (${GREEN}Renamed${WHITE})"

        untracked_files_keys_ref[${i}]="${filename}"
    done
}

function gdiff_callback() {
    local git_file="${GIT_BASE_DIR}/${menu_item_key_selected}"
    case ${key} in
        [vV]|"")
            nvim "${git_file}" -c Gdiffsplit
            ;;
        [aA])
            git add "${git_file}"
            ;;
        [uU])
            git reset "${git_file}"
            ;;
        [cC])
            git commit
            ;;
        [rR])
            git checkout HEAD "${git_file}"
            ;;
        [dD])
            stty echo
            read -n 1 -p $'Delete «\e[1;31m'${git_file}$'\e[0;0m» (y/n)' choice
            stty -echo
            [[ "${choice}" =~ [yY] ]] && rm -f "${git_file}"
            ;;
        [eE])
            ${EDITOR} "${git_file}"
            ;;
    esac

    get_nonstaged_files menu_ref menu_keys_ref

    if (( menu_index >= ${#menu_ref[@]} ))
    then
        menu_index=0
    fi
}

declare -a untracked_files_menu=()
declare -a untracked_files_keys=()
get_nonstaged_files untracked_files_menu untracked_files_keys
ascii_menu_create untracked_files_menu untracked_files_keys "Changes not staged for commit:" "(A)dd (V)iew (R)estore (C)ommit (E)dit (U)nstage (D)elete (Q)uit" gdiff_callback
